# ---------------------------------------------------------------------------
# Airflow + Lazada Dashboard Pipeline — Environment template
# คัดลอกเป็น `.env` แล้วแก้ค่าก่อนรัน docker compose
# ---------------------------------------------------------------------------

# Airflow runtime user (Linux/Mac: ใช้ `id -u` ของ user, Windows: 50000 ใช้ได้)
AIRFLOW_UID=50000

# Airflow web admin
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin

# Shared secret_key สำหรับให้ scheduler/webserver/worker คุยกันเรื่อง logs
# (สำหรับ production แนะนำ generate ใหม่ด้วย: python -c "import secrets; print(secrets.token_hex(32))")
AIRFLOW_SECRET_KEY=lazada-airflow-shared-secret-change-me

# จำนวน rows ต่อไฟล์ Kaggle CSV (ลดเพื่อทดสอบให้เร็ว, เพิ่มสำหรับ production)
LAZADA_ROWS_PER_FILE=25000000

# Kaggle API credentials (ถ้าใช้ private dataset). สร้างจาก
# https://www.kaggle.com/settings/account -> "Create New Token"
KAGGLE_USERNAME=
KAGGLE_KEY=
